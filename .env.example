FLASK_ENV=development
FLASK_APP=app.py
# Set to 0 in production!
FLASK_DEBUG=1

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-strong-random-secret-here

# Firebase Admin SDK credentials - never commit the JSON service account file.
# Option 1: absolute or relative path to your service account JSON file.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# Option 2: JSON content in one environment variable instead of a file.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

FIREBASE_DATABASE_URL=https://neuro-rewire-default-rtdb.firebaseio.com
FIREBASE_CHECK_REVOKED_TOKENS=true

# Frontend origins allowed to call /api/* from a browser.
# In production replace these with your real HTTPS domain(s).
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

# Server-side Firebase session cookie.
FIREBASE_SESSION_COOKIE_NAME=nrw_session
FIREBASE_SESSION_COOKIE_DAYS=5
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# Speech endpoint limits.
MAX_AUDIO_UPLOAD_BYTES=2097152
ALLOWED_SPEECH_LANGUAGES=ar-DZ,fr-FR,en-US,en-GB

# Rate limiting. Use Redis in production, not memory://.
RATELIMIT_DEFAULTS=200 per day,60 per hour
RATELIMIT_STORAGE_URI=memory://
# Example production value:
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0
